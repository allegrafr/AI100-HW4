import requests

# Ollama server URL
OLLAMA_URL = "http://localhost:11434/api/generate"

# Choose a model, for example, "phi3"
MODEL = "phi3"

# Function to send a prompt to Ollama
def query_model(prompt: str) -> str:
    try:
        # Send request to the local Ollama model
        response = requests.post(OLLAMA_URL, json={
            "model": MODEL,
            "prompt": prompt,
            "stream": False  # Set to True if you want streaming
        }, timeout=120)

        response.raise_for_status()  # Raise an exception for invalid responses
        return response.json().get('response', '')  # Get the model's response
    except requests.RequestException as e:
        print(f"Error: {e}")
        return None

# Example usage:
prompt = "Explain the concept of concurrency in programming."
result = query_model(prompt)
print(f"Model Response: {result}")
